<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F2F2F2">

    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginBottom="24dp"
        android:background="#DCE8F4"
        android:gravity="bottom|end"
        android:padding="16dp"
        android:text=""
        android:textColor="#000000"
        android:textSize="48sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn7"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#4285F4"
        android:text="7"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:cornerRadius="35dp"
        app:layout_constraintTop_toBottomOf="@id/tvDisplay"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn8" />

    <Button
        android:id="@+id/btn8"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#4285F4"
        android:text="8"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:cornerRadius="35dp"
        app:layout_constraintTop_toTopOf="@id/btn7"
        app:layout_constraintStart_toEndOf="@id/btn7"
        app:layout_constraintEnd_toStartOf="@id/btn9" />

    <Button
        android:id="@+id/btn9"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#4285F4"
        android:text="9"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:cornerRadius="35dp"
        app:layout_constraintTop_toTopOf="@id/btn7"
        app:layout_constraintStart_toEndOf="@id/btn8"
        app:layout_constraintEnd_toStartOf="@id/btnPlus" />

    <Button
        android:id="@+id/btnPlus"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#000000"
        android:text="+"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        app:cornerRadius="35dp"
        app:layout_constraintTop_toTopOf="@id/btn7"
        app:layout_constraintStart_toEndOf="@id/btn9"
        app:layout_constraintEnd_toStartOf="@id/btnFraction" />

    <Button
        android:id="@+id/btnFraction"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#FFFFFF"
        android:text="%"
        android:textColor="#D32F2F"
        android:textSize="18sp"
        app:strokeColor="#D32F2F"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toTopOf="@id/btn7"
        app:layout_constraintStart_toEndOf="@id/btnPlus"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn4"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#4285F4"
        android:text="4"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:cornerRadius="35dp"
        app:layout_constraintTop_toBottomOf="@id/btn7"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn5" />

    <Button
        android:id="@+id/btn5"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#4285F4"
        android:text="5"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:cornerRadius="35dp"
        app:layout_constraintTop_toTopOf="@id/btn4"
        app:layout_constraintStart_toEndOf="@id/btn4"
        app:layout_constraintEnd_toStartOf="@id/btn6" />

    <Button
        android:id="@+id/btn6"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#4285F4"
        android:text="6"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:cornerRadius="35dp"
        app:layout_constraintTop_toTopOf="@id/btn4"
        app:layout_constraintStart_toEndOf="@id/btn5"
        app:layout_constraintEnd_toStartOf="@id/btnMinus" />

    <Button
        android:id="@+id/btnMinus"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#000000"
        android:text="-"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        app:cornerRadius="35dp"
        app:layout_constraintTop_toTopOf="@id/btn4"
        app:layout_constraintStart_toEndOf="@id/btn6"
        app:layout_constraintEnd_toStartOf="@id/btnInverse" />

    <Button
        android:id="@+id/btnInverse"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#FFFFFF"
        android:text="1/x"
        android:textColor="#D32F2F"
        android:textSize="18sp"
        app:strokeColor="#D32F2F"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toTopOf="@id/btn4"
        app:layout_constraintStart_toEndOf="@id/btnMinus"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn1"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#4285F4"
        android:text="1"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:cornerRadius="35dp"
        app:layout_constraintTop_toBottomOf="@id/btn4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn2" />

    <Button
        android:id="@+id/btn2"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#4285F4"
        android:text="2"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:cornerRadius="35dp"
        app:layout_constraintTop_toTopOf="@id/btn1"
        app:layout_constraintStart_toEndOf="@id/btn1"
        app:layout_constraintEnd_toStartOf="@id/btn3" />

    <Button
        android:id="@+id/btn3"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#4285F4"
        android:text="3"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:cornerRadius="35dp"
        app:layout_constraintTop_toTopOf="@id/btn1"
        app:layout_constraintStart_toEndOf="@id/btn2"
        app:layout_constraintEnd_toStartOf="@id/btnMultiply" />

    <Button
        android:id="@+id/btnMultiply"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#000000"
        android:text="*"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        app:cornerRadius="35dp"
        app:layout_constraintTop_toTopOf="@id/btn1"
        app:layout_constraintStart_toEndOf="@id/btn3"
        app:layout_constraintEnd_toStartOf="@id/btnPower" />

    <Button
        android:id="@+id/btnPower"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#FFFFFF"
        android:text="x^y"
        android:textColor="#D32F2F"
        android:textSize="18sp"
        app:strokeColor="#D32F2F"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toTopOf="@id/btn1"
        app:layout_constraintStart_toEndOf="@id/btnMultiply"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn0"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#4285F4"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:cornerRadius="35dp"
        app:layout_constraintTop_toBottomOf="@id/btn1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnClear" />

    <Button
        android:id="@+id/btnClear"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#000000"
        android:text="C"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:cornerRadius="35dp"
        app:layout_constraintTop_toTopOf="@id/btn0"
        app:layout_constraintStart_toEndOf="@id/btn0"
        app:layout_constraintEnd_toStartOf="@id/btnEquals" />

    <Button
        android:id="@+id/btnEquals"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#000000"
        android:text="="
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        app:cornerRadius="35dp"
        app:layout_constraintTop_toTopOf="@id/btn0"
        app:layout_constraintStart_toEndOf="@id/btnClear"
        app:layout_constraintEnd_toStartOf="@id/btnDivide" />

    <Button
        android:id="@+id/btnDivide"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#000000"
        android:text="/"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        app:cornerRadius="35dp"
        app:layout_constraintTop_toTopOf="@id/btn0"
        app:layout_constraintStart_toEndOf="@id/btnEquals"
        app:layout_constraintEnd_toStartOf="@id/btnRoot" />

    <Button
        android:id="@+id/btnRoot"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="4dp"
        android:backgroundTint="#FFFFFF"
        android:text="y√x"
        android:textColor="#D32F2F"
        android:textSize="18sp"
        app:strokeColor="#D32F2F"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toTopOf="@id/btn0"
        app:layout_constraintStart_toEndOf="@id/btnDivide"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>